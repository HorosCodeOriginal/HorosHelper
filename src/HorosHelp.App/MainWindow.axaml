<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:HorosHelp.UI.Views.Shell"
        x:Class="HorosHelp.App.MainWindow"
        Title="HorosHelper"
        Icon="/Assets/horoshelper.ico"
        Width="1280"
        Height="800"
        MinWidth="960"
        MinHeight="640"
        WindowDecorations="None"
        Background="{DynamicResource BrushBackgroundBase}">
  <views:ShellView />
</Window>
