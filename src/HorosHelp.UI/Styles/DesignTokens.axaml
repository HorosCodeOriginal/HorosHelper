<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- HorosHelper Slate + Amber (Mockup-01) -->
  <Color x:Key="ColorBackgroundBase">#0F172A</Color>
  <Color x:Key="ColorSurfaceElevated">#1E293B</Color>
  <Color x:Key="ColorSurfaceSidebar">#1E293B</Color>
  <Color x:Key="ColorAccentPrimary">#F59E0B</Color>
  <Color x:Key="ColorAccentPrimaryMuted">#33F59E0B</Color>
  <Color x:Key="ColorTextPrimary">#F8FAFC</Color>
  <Color x:Key="ColorTextSecondary">#94A3B8</Color>
  <Color x:Key="ColorTextMuted">#64748B</Color>
  <Color x:Key="ColorBorder">#334155</Color>
  <Color x:Key="ColorBorderFocus">#F59E0B</Color>
  <Color x:Key="ColorStatusOk">#22C55E</Color>
  <Color x:Key="ColorTitleBar">#0E1318</Color>

  <SolidColorBrush x:Key="BrushBackgroundBase" Color="{StaticResource ColorBackgroundBase}" />
  <SolidColorBrush x:Key="BrushSurfaceElevated" Color="{StaticResource ColorSurfaceElevated}" />
  <SolidColorBrush x:Key="BrushSurfaceSidebar" Color="{StaticResource ColorSurfaceSidebar}" />
  <SolidColorBrush x:Key="BrushAccentPrimary" Color="{StaticResource ColorAccentPrimary}" />
  <SolidColorBrush x:Key="BrushAccentPrimaryMuted" Color="{StaticResource ColorAccentPrimaryMuted}" />
  <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}" />
  <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}" />
  <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMuted}" />
  <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}" />
  <SolidColorBrush x:Key="BrushBorderFocus" Color="{StaticResource ColorBorderFocus}" />
  <SolidColorBrush x:Key="BrushStatusOk" Color="{StaticResource ColorStatusOk}" />
  <SolidColorBrush x:Key="BrushTitleBar" Color="{StaticResource ColorTitleBar}" />

  <Thickness x:Key="Spacing1">4</Thickness>
  <Thickness x:Key="Spacing2">8</Thickness>
  <Thickness x:Key="Spacing3">12</Thickness>
  <Thickness x:Key="Spacing4">16</Thickness>
  <Thickness x:Key="Spacing5">20</Thickness>
  <Thickness x:Key="Spacing6">24</Thickness>

  <CornerRadius x:Key="RadiusSm">4</CornerRadius>
  <CornerRadius x:Key="RadiusMd">8</CornerRadius>
  <CornerRadius x:Key="RadiusLg">12</CornerRadius>

  <x:Double x:Key="SidebarWidth">199</x:Double>
  <x:Double x:Key="TitleBarHeight">46</x:Double>
  <x:Double x:Key="StatusBarHeight">36</x:Double>
  <x:Double x:Key="NavItemHeight">40</x:Double>

</ResourceDictionary>
