<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HorosHelp.UI.ViewModels.Features"
             x:Class="HorosHelp.UI.Views.Features.AppsView"
             x:Name="Root"
             x:DataType="vm:AppsViewModel">

  <Grid RowDefinitions="Auto,14,Auto,14,*" Margin="24,20,24,20">

    <!-- ═══ Header ═══ -->
    <StackPanel Spacing="4">
      <TextBlock Text="{Binding Title}"
                 FontSize="28" FontWeight="Bold"
                 Foreground="{DynamicResource BrushTextPrimary}" />
      <TextBlock Text="{Binding Subtitle}"
                 FontSize="13"
                 Foreground="{DynamicResource BrushTextSecondary}" />
    </StackPanel>

    <!-- ═══ Tabs ═══ -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="24">
      <Button Command="{Binding SelectAppsTabCommand}"
              Background="Transparent"
              BorderThickness="0,0,0,2"
              BorderBrush="{DynamicResource BrushAccentPrimary}"
              Padding="0,0,0,8"
              IsVisible="{Binding IsAppsTabSelected}">
        <TextBlock Text="Anwendungen"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource BrushAccentPrimary}" />
      </Button>
      <Button Command="{Binding SelectAppsTabCommand}"
              Background="Transparent"
              BorderThickness="0"
              Padding="0,0,0,8"
              IsVisible="{Binding !IsAppsTabSelected}">
        <TextBlock Text="Anwendungen"
                   FontSize="14"
                   Foreground="{DynamicResource BrushTextSecondary}" />
      </Button>

      <Button Command="{Binding SelectDriversTabCommand}"
              Background="Transparent"
              BorderThickness="0,0,0,2"
              BorderBrush="{DynamicResource BrushAccentPrimary}"
              Padding="0,0,0,8"
              IsVisible="{Binding !IsAppsTabSelected}">
        <TextBlock Text="Treiber"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource BrushAccentPrimary}" />
      </Button>
      <Button Command="{Binding SelectDriversTabCommand}"
              Background="Transparent"
              BorderThickness="0"
              Padding="0,0,0,8"
              IsVisible="{Binding IsAppsTabSelected}">
        <TextBlock Text="Treiber"
                   FontSize="14"
                   Foreground="{DynamicResource BrushTextSecondary}" />
      </Button>
    </StackPanel>

    <!-- ═══ Apps Tab Content ═══ -->
    <Grid Grid.Row="4" IsVisible="{Binding IsAppsTabSelected}"
          RowDefinitions="Auto,10,*">

      <!-- Filter bar -->
      <Grid ColumnDefinitions="*,Auto,Auto,Auto">
        <Border Background="{DynamicResource BrushSurfaceElevated}"
                CornerRadius="{DynamicResource RadiusMd}"
                Padding="12,8"
                Margin="0,0,8,0">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="⌕"
                       FontSize="14"
                       Foreground="{DynamicResource BrushTextMuted}"
                       VerticalAlignment="Center" />
            <TextBox Text="{Binding SearchText}"
                     PlaceholderText="App suchen..."
                     Background="Transparent"
                     BorderThickness="0"
                     FontSize="13"
                     Foreground="{DynamicResource BrushTextPrimary}"
                     VerticalAlignment="Center"
                     MinWidth="200" />
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource BrushSurfaceElevated}"
                CornerRadius="{DynamicResource RadiusMd}"
                Padding="12,8" Margin="0,0,8,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Kategorie" FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       VerticalAlignment="Center" />
            <TextBlock Text="∨" FontSize="11"
                       Foreground="{DynamicResource BrushTextMuted}"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Border>

        <Border Grid.Column="2" Background="{DynamicResource BrushSurfaceElevated}"
                CornerRadius="{DynamicResource RadiusMd}"
                Padding="12,8" Margin="0,0,8,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Größe" FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       VerticalAlignment="Center" />
            <TextBlock Text="∨" FontSize="11"
                       Foreground="{DynamicResource BrushTextMuted}"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Border>

        <Border Grid.Column="3" Background="{DynamicResource BrushSurfaceElevated}"
                CornerRadius="{DynamicResource RadiusMd}"
                Padding="12,8">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Alter" FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       VerticalAlignment="Center" />
            <TextBlock Text="∨" FontSize="11"
                       Foreground="{DynamicResource BrushTextMuted}"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Apps table -->
      <Border Grid.Row="2"
              Background="{DynamicResource BrushSurfaceElevated}"
              CornerRadius="{DynamicResource RadiusLg}"
              ClipToBounds="True">
        <Grid RowDefinitions="Auto,*">

          <!-- Table header -->
          <Border BorderBrush="{DynamicResource BrushBorder}"
                  BorderThickness="0,0,0,1"
                  Padding="16,12">
            <Grid ColumnDefinitions="2*,1.2*,0.8*,0.9*,Auto">
              <TextBlock Text="Name" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushTextMuted}" />
              <TextBlock Grid.Column="1" Text="Version" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushTextMuted}" />
              <TextBlock Grid.Column="2" Text="Größe" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushTextMuted}" />
              <TextBlock Grid.Column="3" Text="Installiert" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushTextMuted}" />
              <TextBlock Grid.Column="4" Text="Aktion" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushTextMuted}"
                         HorizontalAlignment="Center" />
            </Grid>
          </Border>

          <!-- Table rows -->
          <ScrollViewer Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Apps}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:AppTableRowItem">
                  <Border BorderBrush="{DynamicResource BrushBorder}"
                          BorderThickness="0,0,0,1"
                          Padding="16,12">
                    <Grid ColumnDefinitions="2*,1.2*,0.8*,0.9*,Auto">
                      <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="28" Height="28"
                                CornerRadius="{DynamicResource RadiusSm}"
                                Background="{Binding IconBackground}">
                          <TextBlock Text="{Binding IconGlyph}"
                                     FontSize="12" FontWeight="Bold"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Foreground="White" />
                        </Border>
                        <TextBlock Text="{Binding Name}"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   VerticalAlignment="Center" />
                      </StackPanel>

                      <TextBlock Grid.Column="1" Text="{Binding Version}"
                                 FontSize="12"
                                 Foreground="{DynamicResource BrushTextSecondary}"
                                 VerticalAlignment="Center" />
                      <TextBlock Grid.Column="2" Text="{Binding Size}"
                                 FontSize="12"
                                 Foreground="{DynamicResource BrushTextSecondary}"
                                 VerticalAlignment="Center" />
                      <TextBlock Grid.Column="3" Text="{Binding Installed}"
                                 FontSize="12"
                                 Foreground="{DynamicResource BrushTextSecondary}"
                                 VerticalAlignment="Center" />

                      <Button Grid.Column="4"
                              Command="{Binding #Root.DataContext.UninstallAppCommand}"
                              CommandParameter="{Binding}"
                              Content="Deinstallieren"
                              FontSize="11"
                              Padding="12,6"
                              CornerRadius="{DynamicResource RadiusMd}"
                              Background="Transparent"
                              BorderBrush="{DynamicResource BrushAccentPrimary}"
                              BorderThickness="1"
                              Foreground="{DynamicResource BrushAccentPrimary}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

        </Grid>
      </Border>
    </Grid>

    <!-- ═══ Drivers Tab Content ═══ -->
    <Border Grid.Row="4"
            IsVisible="{Binding !IsAppsTabSelected}"
            Background="{DynamicResource BrushSurfaceElevated}"
            CornerRadius="{DynamicResource RadiusLg}"
            ClipToBounds="True">
      <Grid RowDefinitions="Auto,*">

        <!-- Table header -->
        <Border BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
          <Grid ColumnDefinitions="2*,0.8*,1.2*,0.9*,0.8*,Auto">
            <TextBlock Text="Treiber" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}" />
            <TextBlock Grid.Column="1" Text="Version" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}" />
            <TextBlock Grid.Column="2" Text="Anbieter" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}" />
            <TextBlock Grid.Column="3" Text="Installiert" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}" />
            <TextBlock Grid.Column="4" Text="Status" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}" />
            <TextBlock Grid.Column="5" Text="Aktion" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}"
                       HorizontalAlignment="Center" />
          </Grid>
        </Border>

        <!-- Driver rows -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Drivers}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:DriverTableRowItem">
              <Border BorderBrush="{DynamicResource BrushBorder}"
                      BorderThickness="0,0,0,1"
                      Padding="16,12">
                <Grid ColumnDefinitions="2*,0.8*,1.2*,0.9*,0.8*,Auto">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="28" Height="28"
                            CornerRadius="{DynamicResource RadiusSm}"
                            Background="{Binding IconBackground}">
                      <TextBlock Text="{Binding IconGlyph}"
                                 FontSize="12" FontWeight="Bold"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Foreground="White" />
                    </Border>
                    <TextBlock Text="{Binding Name}"
                               FontSize="13"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               VerticalAlignment="Center" />
                  </StackPanel>

                  <TextBlock Grid.Column="1" Text="{Binding Version}"
                             FontSize="12"
                             Foreground="{DynamicResource BrushTextSecondary}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2" Text="{Binding Provider}"
                             FontSize="12"
                             Foreground="{DynamicResource BrushTextSecondary}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="3" Text="{Binding Installed}"
                             FontSize="12"
                             Foreground="{DynamicResource BrushTextSecondary}"
                             VerticalAlignment="Center" />

                  <Border Grid.Column="4"
                          CornerRadius="10"
                          Padding="8,3"
                          Background="{Binding StatusBackground}"
                          BorderBrush="{Binding StatusBorder}"
                          BorderThickness="1"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusLabel}"
                               FontSize="11" FontWeight="Medium"
                               Foreground="{Binding StatusForeground}" />
                  </Border>

                  <StackPanel Grid.Column="5"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                    <Button IsVisible="{Binding ShowUpdateAction}"
                            Command="{Binding #Root.DataContext.UpdateDriverCommand}"
                            CommandParameter="{Binding}"
                            Content="↻"
                            FontSize="14"
                            Width="32" Height="32"
                            Padding="0"
                            CornerRadius="{DynamicResource RadiusMd}"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BrushAccentPrimary}"
                            BorderThickness="1"
                            Foreground="{DynamicResource BrushAccentPrimary}" />
                    <TextBlock IsVisible="{Binding !ShowUpdateAction}"
                               Text="—"
                               FontSize="14"
                               Foreground="{DynamicResource BrushTextMuted}"
                               HorizontalAlignment="Center" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </Grid>
    </Border>

  </Grid>
</UserControl>
