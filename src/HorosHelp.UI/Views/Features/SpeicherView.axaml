<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HorosHelp.UI.ViewModels.Features"
             xmlns:controls="using:HorosHelp.UI.Controls"
             x:Class="HorosHelp.UI.Views.Features.SpeicherView"
             x:DataType="vm:SpeicherViewModel">

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="24,20,24,20">

    <!-- Header -->
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,14">
      <TextBlock Text="{Binding Title}"
                 FontSize="28" FontWeight="Bold"
                 Foreground="{DynamicResource BrushTextPrimary}" />
      <TextBlock Text="{Binding Subtitle}"
                 FontSize="13"
                 Foreground="{DynamicResource BrushTextSecondary}" />
    </StackPanel>

    <!-- Drive cards -->
    <ItemsControl Grid.Row="1" ItemsSource="{Binding DriveCards}" Margin="0,0,0,14">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <UniformGrid Rows="1" Columns="2" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:DriveCardItem">
          <Border Background="{DynamicResource BrushSurfaceElevated}"
                  CornerRadius="{DynamicResource RadiusLg}"
                  Margin="0,0,8,0"
                  Padding="18,16">
            <Grid ColumnDefinitions="*,Auto">

              <StackPanel Spacing="10">
                <!-- Drive header -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="{Binding IconGlyph}"
                             FontSize="18"
                             VerticalAlignment="Center" />
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding Title}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextPrimary}" />
                    <TextBlock Text="{Binding MediaType}"
                               FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}" />
                  </StackPanel>
                </StackPanel>

                <!-- Horizontal progress -->
                <ProgressBar Value="{Binding ProgressValue}"
                             Minimum="0" Maximum="100"
                             Height="6"
                             CornerRadius="3"
                             Background="#334155"
                             Foreground="{DynamicResource BrushAccentPrimary}" />

                <TextBlock Text="{Binding UsedText}"
                           FontSize="12"
                           Foreground="{DynamicResource BrushTextSecondary}" />
                <TextBlock Text="{Binding FreeText}"
                           FontSize="11"
                           Foreground="{DynamicResource BrushTextMuted}" />
              </StackPanel>

              <!-- Storage ring -->
              <Grid Grid.Column="1"
                    MinWidth="96" MinHeight="96"
                    Margin="14,2,2,2"
                    VerticalAlignment="Center">
                <controls:ProgressRing Diameter="84"
                                       StrokeThickness="8"
                                       Value="{Binding PercentUsed}"
                                       ProgressBrush="{DynamicResource BrushAccentPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="2"
                            Margin="4">
                  <TextBlock Text="{Binding PercentText}"
                             FontSize="18" FontWeight="Bold"
                             HorizontalAlignment="Center"
                             Foreground="{DynamicResource BrushTextPrimary}" />
                  <TextBlock Text="verwendet"
                             FontSize="11"
                             HorizontalAlignment="Center"
                             Foreground="{DynamicResource BrushTextMuted}" />
                </StackPanel>
              </Grid>

            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Middle: breakdown + skeleton panel -->
    <Grid Grid.Row="2" ColumnDefinitions="*,12,*" Margin="0,0,0,14">

      <!-- Speicherbelegung -->
      <Border Background="{DynamicResource BrushSurfaceElevated}"
              CornerRadius="{DynamicResource RadiusLg}"
              Padding="18,16">
        <StackPanel Spacing="12">
          <TextBlock Text="{Binding BreakdownTitle}"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextPrimary}" />

          <ItemsControl ItemsSource="{Binding StorageCategories}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:StorageCategoryItem">
                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,10">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Name}"
                               FontSize="12"
                               Foreground="{DynamicResource BrushTextPrimary}" />
                    <ProgressBar Value="{Binding ProgressValue}"
                                 Minimum="0" Maximum="35"
                                 Height="4"
                                 CornerRadius="2"
                                 Background="#334155"
                                 Foreground="{DynamicResource BrushAccentPrimary}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             Text="{Binding SizeText}"
                             FontSize="11"
                             VerticalAlignment="Center"
                             Margin="12,0,8,0"
                             Foreground="{DynamicResource BrushTextSecondary}" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding PercentText}"
                             FontSize="11"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource BrushTextMuted}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Bereinigungsvorschläge chart -->
      <Border Grid.Column="2"
              Background="{DynamicResource BrushSurfaceElevated}"
              CornerRadius="{DynamicResource RadiusLg}"
              Padding="18,16">
        <Grid RowDefinitions="Auto,*,Auto">

          <TextBlock Grid.Row="0"
                     Text="{Binding CleanupChartTitle}"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextPrimary}"
                     Margin="0,0,0,12" />

          <Grid Grid.Row="1" ColumnDefinitions="Auto,*" VerticalAlignment="Center">
            <Grid MinWidth="88" MinHeight="88"
                  Margin="2,0,16,0"
                  VerticalAlignment="Center">
              <controls:ProgressRing Diameter="72"
                                     StrokeThickness="10"
                                     Value="{Binding CleanupChartPercent}"
                                     ProgressBrush="{DynamicResource BrushAccentPrimary}"
                                     TrackBrush="{DynamicResource BrushBorder}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
              <StackPanel HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Spacing="0">
                <TextBlock Text="{Binding CleanupChartTotal}"
                           FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource BrushAccentPrimary}" />
                <TextBlock Text="freigebbar"
                           FontSize="10"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource BrushTextMuted}" />
              </StackPanel>
            </Grid>

            <ItemsControl Grid.Column="1"
                          ItemsSource="{Binding CleanupSuggestions}"
                          VerticalAlignment="Center">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:CleanupSuggestionItem">
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Name}"
                                 FontSize="12"
                                 Foreground="{DynamicResource BrushTextPrimary}" />
                      <ProgressBar Value="{Binding ProgressValue}"
                                   Minimum="0" Maximum="100"
                                   Height="4"
                                   CornerRadius="2"
                                   Background="#334155"
                                   Foreground="{DynamicResource BrushAccentPrimary}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SizeText}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Foreground="{DynamicResource BrushTextSecondary}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>

          <TextBlock Grid.Row="2"
                     Text="Sicher entfernbare Dateien nach Kategorie"
                     FontSize="11"
                     Margin="0,12,0,0"
                     Foreground="{DynamicResource BrushTextMuted}" />
        </Grid>
      </Border>

    </Grid>

    <!-- Cleanup CTA -->
    <Border Grid.Row="3"
            Background="{DynamicResource BrushSurfaceElevated}"
            CornerRadius="{DynamicResource RadiusLg}"
            Padding="18,16">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="6" VerticalAlignment="Center">
          <TextBlock Text="{Binding CleanupTitle}"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextPrimary}" />
          <TextBlock Text="{Binding CleanupDescription}"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource BrushTextSecondary}" />
        </StackPanel>

        <Button Grid.Column="1"
                Command="{Binding CleanupCommand}"
                VerticalAlignment="Center"
                Padding="20,12"
                Margin="16,0,0,0"
                CornerRadius="{DynamicResource RadiusMd}"
                Foreground="#0F172A"
                BorderThickness="0">
          <Button.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
              <GradientStop Color="#F59E0B" Offset="0" />
              <GradientStop Color="#D97706" Offset="1" />
            </LinearGradientBrush>
          </Button.Background>
          <Button.Styles>
            <Style Selector="Button:pointerover /template/ ContentPresenter">
              <Setter Property="Background">
                <Setter.Value>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#FBBF24" Offset="0" />
                    <GradientStop Color="#F59E0B" Offset="1" />
                  </LinearGradientBrush>
                </Setter.Value>
              </Setter>
            </Style>
          </Button.Styles>
          <TextBlock Text="{Binding CleanupButtonText}"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="#0F172A" />
        </Button>
      </Grid>
    </Border>

  </Grid>
</UserControl>
